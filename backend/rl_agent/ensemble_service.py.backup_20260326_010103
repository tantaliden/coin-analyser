def main():
    global running

    print("=" * 70)
    print("  RL Ensemble Trading Service — CNN + V10/V11 Jury")
    print(f"  CNN-Threshold: {CNN_CONFIDENCE_THRESHOLD}% | Max: {MAX_CONCURRENT} Positionen")
    print(f"  Entry: {ENTRY_INTERVAL}s, Management: {MGMT_INTERVAL}s")
    print(f"  Lernen: Nach je {LEARN_BATCH_SIZE} Erfahrungen")
    print(f"  V10: {V10_MODEL_PATH}")
    print(f"  V11: {V11_MODEL_PATH}")
    print("=" * 70)

    # Modelle pruefen
    if not Path(V10_MODEL_PATH).exists():
        logger.error(f"V10 Modell nicht gefunden: {V10_MODEL_PATH}")
        return
    if not Path(V11_MODEL_PATH).exists():
        logger.error(f"V11 Modell nicht gefunden: {V11_MODEL_PATH}")
        return

    # CNN laden
    cnn = get_cnn_model()
    if cnn is None:
        logger.error("CNN-Modell konnte nicht geladen werden!")
        return
    logger.info("CNN-Modell geladen")

    # RL-Modelle laden
    model_v10 = PPO.load(V10_MODEL_PATH)
    logger.info(f"V10 Modell geladen: {V10_MODEL_PATH}")

    model_v11 = PPO.load(V11_MODEL_PATH)
    logger.info(f"V11 Modell geladen: {V11_MODEL_PATH}")

    state = load_state()

    creds = get_hl_credentials()
    if not creds:
        logger.error("Keine Hyperliquid Credentials!")
        return

    refresh_hl_coin_info()

    # Tradeable Coins + Liquiditaets-Filter
    app_conn = get_conn('app')
    tradeable_coins = get_tradeable_coins(app_conn)
    app_conn.close()
    liquid_coins = update_liquid_coins(tradeable_coins)
    last_volume_check = time.time()

    logger.info(f"Punkte: {state['total_points']:.0f} | Profit: ${state['total_profit']:.2f} | "
                f"Trades: {state.get('total_trades', 0)} | Skips: {state.get('total_skips', 0)}")

    last_scan_time = 0
    last_mgmt_time = 0
    iteration = 0

    while running:
        try:
            _check_day_rollover(state)
            _check_week_rollover(state)

            app_conn = get_conn('app')

            config = get_agent_config(app_conn)
            if not config['is_active']:
                app_conn.close()
                time.sleep(POLL_INTERVAL)
                continue

            # 1. Pending-Close Check (jede Iteration, 30s)
            check_pending_closes(app_conn, state, creds)

            # 1b. Skip-Outcomes pruefen (jede Iteration, via klines High/Low)
            try:
                check_skip_outcomes()
            except:
                pass

            now_ts = time.time()

            # Liquiditaets-Check 1x taeglich
            if now_ts - last_volume_check >= 86400:
                liquid_coins = update_liquid_coins(tradeable_coins)
                last_volume_check = now_ts

            # 2. Position-Management (alle 5 Min, nur V11)
            if now_ts - last_mgmt_time >= MGMT_INTERVAL:
                coins_conn = get_conn('coins')
                manage_positions(model_v11, app_conn, coins_conn, state, creds)
                coins_conn.close()
                last_mgmt_time = now_ts

            # 3. CNN-Scan + Ensemble-Entry (alle 5 Min)
            if now_ts - last_scan_time >= ENTRY_INTERVAL:
                coins_conn = get_conn('coins')
                cnn_scan_and_ensemble_entry(model_v10, model_v11, app_conn, coins_conn,
                                            state, creds, liquid_coins)
                coins_conn.close()
                last_scan_time = now_ts

            # 4. Experience-Lernen
            if len(experience_buffer) >= LEARN_BATCH_SIZE:
                logger.info(f"[ENSEMBLE] Experience-Lernen starten: {len(experience_buffer)} Erfahrungen")
                experience_learn_ensemble(model_v10, model_v11, list(experience_buffer))
                experience_buffer.clear()

            app_conn.close()

            iteration += 1
            if iteration % 60 == 0:  # Alle ~30 Min Status
                n_open = 0
                try:
                    app_conn = get_conn('app')
                    positions = get_open_positions_db(app_conn)
                    n_open = len(positions)
                    app_conn.close()
                except:
                    pass
                hl_bal = get_hl_balance(creds['wallet_address'])
                total_trades = state.get('total_trades', 0)
                total_skips = state.get('total_skips', 0)
                total_wins = state.get('total_wins', 0)
                total_losses = state.get('total_losses', 0)
                win_rate = total_wins / (total_wins + total_losses) * 100 if (total_wins + total_losses) > 0 else 0
                logger.info(f"[ENSEMBLE] Status | HL: ${hl_bal:.2f} | "
                            f"Profit: ${state['total_profit']:.2f} | "
                            f"Punkte: {state['total_points']:.0f} | "
                            f"Offen: {n_open} | "
                            f"Trades: {total_trades} Skips: {total_skips} | "
                            f"WR: {win_rate:.1f}% ({total_wins}W/{total_losses}L) | "
                            f"Buffer: {len(experience_buffer)}/{LEARN_BATCH_SIZE} | "
                            f"CNN-Scans: {state.get('cnn_scans', 0)} Signals: {state.get('cnn_signals', 0)}")

        except Exception as e:
            logger.error(f"Fehler im Hauptloop: {e}")
            traceback.print_exc()
            try:
                app_conn.close()
            except:
                pass

        time.sleep(POLL_INTERVAL)

    save_state(state)
    logger.info("Ensemble-Service gestoppt, State gespeichert")


if __name__ == '__main__':
    main()
