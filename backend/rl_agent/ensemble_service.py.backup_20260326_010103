# ============================================
# ENSEMBLE JURY
# ============================================

def ensemble_decide(model_v10, model_v11, obs):
    """
    Beide Modelle befragen, Consensus pruefen.
    Beide long -> Trade long (V11-Hebel)
    Beide short -> Trade short (V11-Hebel)
    Uneinig/Skip -> Skip
    """
    action_v10, _ = model_v10.predict(obs, deterministic=False)
    action_v11, _ = model_v11.predict(obs, deterministic=False)

    action_v10 = int(action_v10)
    action_v11 = int(action_v11)

    # Direction extrahieren
    if 1 <= action_v10 <= 10:
        dir_v10 = 'long'
    elif 11 <= action_v10 <= 20:
        dir_v10 = 'short'
    else:
        dir_v10 = 'skip'

    if 1 <= action_v11 <= 10:
        dir_v11 = 'long'
    elif 11 <= action_v11 <= 20:
        dir_v11 = 'short'
    else:
        dir_v11 = 'skip'

    # Consensus Check
    if dir_v10 == dir_v11 and dir_v10 != 'skip':
        leverage = LEVERAGE_MAP[action_v11]
        return {
            'consensus': True,
            'direction': dir_v10,
            'leverage': leverage,
            'action_v10': action_v10,
            'action_v11': action_v11,
            'dir_v10': dir_v10,
            'dir_v11': dir_v11,
        }
    else:
        return {
            'consensus': False,
            'direction': None,
            'action_v10': action_v10,
            'action_v11': action_v11,
            'dir_v10': dir_v10,
            'dir_v11': dir_v11,
        }


