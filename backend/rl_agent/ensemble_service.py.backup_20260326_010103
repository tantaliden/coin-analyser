def cnn_scan_and_ensemble_entry(model_v10, model_v11, app_conn, coins_conn, state, creds, liquid_coins):
    """
    1. CNN scannt alle liquiden Coins (randomisiert)
    2. Bei CNN-Signal: Ensemble-Jury entscheidet
    3. Consensus = Trade, kein Consensus = Skip
    """
    config = get_agent_config(app_conn)
    open_positions = get_open_positions_db(app_conn)
    n_open = len(open_positions)
    open_symbols = {p['symbol'] for p in open_positions}
    now = datetime.now(timezone.utc)

    try:
        prices_hl = get_current_prices_hl()
    except:
        prices_hl = {}

    # Echte HL-Positionsanzahl als Limit
    try:
        hl_positions = get_hl_open_positions(creds['wallet_address'])
        n_open = max(n_open, len(hl_positions))
        for p in hl_positions:
            hl_sym = p.get('coin', '') + 'USDC'
            open_symbols.add(hl_sym)
    except:
        pass

    wallet_balance = get_hl_balance(creds['wallet_address'])
    trades_opened = 0

    # Tages-Trade-Limit
    today = now.strftime('%Y-%m-%d')
    if state.get('trade_day') != today:
        state['trade_day'] = today
        state['trades_today'] = 0

    # CNN-Scan: Alle Coins randomisiert
    shuffled_coins = list(liquid_coins)
    random.shuffle(shuffled_coins)

    coins_cursor = coins_conn.cursor()
    cnn_signals_this_scan = 0

    for symbol in shuffled_coins:
        if n_open >= MAX_CONCURRENT:
            break
        if state.get('trades_today', 0) >= MAX_TRADES_PER_DAY:
            break
        if symbol in open_symbols:
            continue

        coin = symbol.replace('USDC', '').replace('USDT', '')
        current_price = prices_hl.get(coin, 0)
        if current_price <= 0:
            continue

        state['cnn_scans'] = state.get('cnn_scans', 0) + 1

        # CNN-Predict
        try:
            cnn_result = analyze_symbol_cnn(coins_cursor, symbol, current_price, now)
        except Exception as e:
            logger.debug(f"CNN-Fehler {symbol}: {e}")
            continue

        if cnn_result is None:
            continue

        if cnn_result['confidence'] < CNN_CONFIDENCE_THRESHOLD:
            continue

        cnn_signals_this_scan += 1
        state['cnn_signals'] = state.get('cnn_signals', 0) + 1

        # Ensemble-Jury: Observation bauen, beide Modelle befragen
        obs = compute_observation_live(
            coins_conn, symbol, now.replace(tzinfo=None),
            position_state=None,
            n_open_positions=n_open,
        )

        decision = ensemble_decide(model_v10, model_v11, obs)

        lev_v10 = LEVERAGE_MAP_V10.get(decision['action_v10'], 0)
        lev_v11 = LEVERAGE_MAP_V11.get(decision['action_v11'], 0)

        if not decision['consensus']:
            # Skip: Kein Consensus
            state['total_skips'] = state.get('total_skips', 0) + 1
            logger.info(f"[ENSEMBLE] SKIP {symbol} | CNN: {cnn_result['direction']} {cnn_result['confidence']}% | "
                        f"V10={decision['dir_v10']}{f' {lev_v10}x' if decision['dir_v10'] != 'skip' else ''} "
                        f"V11={decision['dir_v11']}{f' {lev_v11}x' if decision['dir_v11'] != 'skip' else ''}")

            # Skip-Tracker: Preis merken fuer spaeteres Feedback
            if decision['dir_v10'] != 'skip' or decision['dir_v11'] != 'skip':
                skip_tracker.append({
                    'symbol': symbol,
                    'coin': coin,
                    'entry_price': current_price,
                    'time': now,
                    'dir_v10': decision['dir_v10'],
                    'dir_v11': decision['dir_v11'],
                    'action_v10': decision['action_v10'],
                    'action_v11': decision['action_v11'],
                })

            # Experience Buffer: Auch Skips merken
            experience_buffer.append({
                'symbol': symbol,
                'entry_time': now.replace(tzinfo=None),
                'exit_time': now.replace(tzinfo=None),
            })
            continue

        # CONSENSUS: Trade ausfuehren
        direction = decision['direction']
        leverage = decision['leverage']

        if leverage > config['max_leverage']:
            leverage = config['max_leverage']

        # Drawdown-Modus
        if state['week_points'] < 0 and leverage > 3:
            leverage = 3

        position_size = _calc_trade_size(wallet_balance, config.get('base_trade_size', BASE_TRADE_SIZE))
        margin = position_size / leverage

        if margin > wallet_balance * 0.5:
            continue

        # Frischer Preis
        try:
            fresh_prices = get_current_prices_hl()
            fresh_price = fresh_prices.get(coin, 0)
            if fresh_price > 0:
                current_price = fresh_price
        except:
            pass

        is_buy = direction == 'long'
        limit_price = round(current_price * (0.999 if is_buy else 1.001), 6)
        result = place_limit_order_hl(creds, coin, is_buy, position_size, limit_price, leverage)

        if not result.get('success'):
            logger.warning(f"HL Order fehlgeschlagen {symbol}: {result.get('error')}")
            continue

        entry_price = result.get('avg_price', limit_price)

        # Position in DB loggen
        pos_id = log_position_open(app_conn, symbol, direction, entry_price, position_size, leverage)
        log_decision(app_conn, pos_id, symbol, decision['action_v11'], None, True, 0.0)

        # Wiederholungs-Tracking
        state.setdefault('last_trade_times', {})[symbol] = now.isoformat()
        state['last_trade_times'] = {
            s: t for s, t in state['last_trade_times'].items()
            if (now - datetime.fromisoformat(t)).total_seconds() < 7200
        }

        n_open += 1
        open_symbols.add(symbol)
        trades_opened += 1
        state['trades_today'] = state.get('trades_today', 0) + 1
        state['total_trades'] = state.get('total_trades', 0) + 1

        logger.info(f"[ENSEMBLE] CONSENSUS {symbol} {direction} {leverage}x | "
                    f"CNN: {cnn_result['direction']} {cnn_result['confidence']}% | "
                    f"V10={decision['dir_v10']} {lev_v10}x V11={decision['dir_v11']} {lev_v11}x | "
                    f"${position_size:.2f} @{entry_price:.4f} | "
                    f"Punkte: {state['total_points']:+.0f}")

    coins_cursor.close()

    if cnn_signals_this_scan > 0:
        logger.info(f"[ENSEMBLE] Scan: {len(shuffled_coins)} Coins, "
                    f"{cnn_signals_this_scan} CNN-Signale, {trades_opened} Trades")

    if trades_opened > 0:
        save_state(state)

    return trades_opened


